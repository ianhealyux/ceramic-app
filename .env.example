# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Single user credentials
APP_USERNAME=
APP_PASSWORD_HASH=  # Generate with: node -e "require('bcryptjs').hash('password', 12).then(console.log)" — escape $ as \$ in .env.local

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# HuggingFace
HUGGINGFACE_API_TOKEN=

# Instagram (mocked for now)
INSTAGRAM_ACCESS_TOKEN=mock
INSTAGRAM_USER_ID=mock

# Anthropic (trends cron)
ANTHROPIC_API_KEY=

# Vercel Blob (temp images)
BLOB_READ_WRITE_TOKEN=

# Vercel KV (trends storage)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Cron Secret
CRON_SECRET=
